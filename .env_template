# ============================================================
# awesome-parenting-skills — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env_template .env
#
# IMPORTANT: Never commit .env to version control.
# .env is already in .gitignore.
#
# TODO: Migrate credentials to macOS Keychain for better security.
#   Use: security add-generic-password -s <service> -a <account> -w <secret>
#   Read: security find-generic-password -s <service> -w
# ============================================================

# ── AgentMail ────────────────────────────────────────────────
# Get your API key from: https://app.agentmail.to/settings/api
AGENTMAIL_API_KEY=your_agentmail_api_key_here

# ── Notification (ntfy.sh) ───────────────────────────────────
# Used by /monitor-registration, /check-grades alerts, etc.
# Pick a unique topic name — anyone who knows it can subscribe.
# Default server: https://ntfy.sh (free, public)
NTFY_TOPIC=your_ntfy_topic_here
NTFY_SERVER=https://ntfy.sh          # Optional: override for self-hosted ntfy

# ── YouTube Data API ─────────────────────────────────────────
# Used by /youtube-kids-audit for channel metadata lookups.
# Get key from: https://console.cloud.google.com → APIs & Services → Credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── Eventbrite API ───────────────────────────────────────────
# Used by /info-gather when eventbrite_api_sancarlos source is enabled.
# Get token from: https://www.eventbrite.com/platform/api-keys
EVENTBRITE_TOKEN=your_eventbrite_token_here

# ── School Portals (optional — for /check-grades) ────────────
# Credentials for school portal automation.
# Alternative: use macOS Keychain (recommended).
# Keychain setup:
#   security add-generic-password -s powerschool -a <username> -w <password>
#   security add-generic-password -s infinite-campus -a <username> -w <password>
#   security add-generic-password -s canvas-observer-token -a observer -w <token>
#
# Uncomment and fill in only if NOT using Keychain:
# POWERSCHOOL_USERNAME=
# POWERSCHOOL_PASSWORD=
# INFINITE_CAMPUS_USERNAME=
# INFINITE_CAMPUS_PASSWORD=
# CANVAS_OBSERVER_TOKEN=

# ── Food Ordering (optional — for /order-food) ───────────────
# Platform API keys (only needed if using API mode, not browser automation).
# Most users should leave these blank and use Tier 1 browser automation instead.
# DOORDASH_DEVELOPER_ID=
# DOORDASH_KEY_ID=
# DOORDASH_SIGNING_SECRET=
