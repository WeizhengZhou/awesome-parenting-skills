# ============================================================
# awesome-parenting-skills — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env_template .env
#
# IMPORTANT: Never commit .env to version control.
# .env is already in .gitignore.
#
# TODO: Migrate credentials to macOS Keychain for better security.
#   Use: security add-generic-password -s <service> -a <account> -w <secret>
#   Read: security find-generic-password -s <service> -w
# ============================================================

# ── AgentMail ────────────────────────────────────────────────
# Get your API key from: https://app.agentmail.to/settings/api
AGENTMAIL_API_KEY=your_agentmail_api_key_here

# ── San Mateo County Library (smcl.org) ──────────────────────
# Your library card login at smcl.org
SMCL_USERNAME=your_library_card_number
SMCL_PASSWORD=your_library_pin

# ── Google Calendars (ICS format) ────────────────────────────
# Get the private ICS URL from Google Calendar → Settings → Integrate calendar
# → "Secret address in iCal format". Treat these URLs as secrets.
# Add one line per calendar. Names before _CALENDAR_ICS are used as calendar labels.
FAMILY_CALENDAR_ICS=https://calendar.google.com/calendar/ical/your-email%40gmail.com/private-abc123.../basic.ics
# LEXI_CALENDAR_ICS=https://...
# SCHOOL_CALENDAR_ICS=https://...
